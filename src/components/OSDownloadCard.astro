---
interface Release {
  rel: string;
  url: string;
}

interface Props {
  title: string;
  items: Release[];
}

const { title, items } = Astro.props;
---

<div class="os-download-card">
  <div class="card" style="background-color: #131313;">
    <div class="card-body">
      <h5 class="card-title">{title}</h5>
      <div class="btn-group py-2" style="width:100%">
        <a href={items[0].url} class="btn btn-dl">{items[0].rel}</a>
        <button
          class="btn btn-dl dropdown-toggle dropdown-toggle-split"
          type="button"
          id={`dropdown${title}Releases`}
          data-bs-toggle="dropdown"
          aria-expanded="false"
        >
          <span class="visually-hidden">Toggle Dropdown</span>
        </button>
        <ul class="dropdown-menu dropdown-dl shadow" aria-labelledby={`dropdown${title}Releases`}>
          {items.map(item => (
            <li><a class="dropdown-item" href={item.url}>{item.rel}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  @import '../styles/vars';

  .btn-dl {
    padding: 0.8em;
    border: 1px solid $dark-200;
    box-shadow: none;
    text-align: left;
    color: #fff;

    &:hover,
    &:focus {
      background-color: $dark-200;
    }
  }

  .dropdown-toggle {
    display: flex;
    justify-content: center;
    max-width: 40px;

    &:after {
      border: 0;
      font-family: "Font Awesome 5 Free";
      font-weight: 900;
      content: "\f078";
    }
  }

  .dropdown-dl {
    background-color: $dark-600;
    border: 0;
    width: 100%;
    transform: translate(0px, 62px) !important;

    .dropdown-item {
      color: rgba(#fff, 0.87);
    }

    .dropdown-item:hover,
    .dropdown-item:focus {
      background-color: $primary;
    }
  }
</style>
